# Core
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Auth JWT
JWT_SECRET=replace_with_secure_value
JWT_REFRESH_SECRET=replace_with_secure_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google OAuth (scaffold)
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Cloudflare Turnstile (scaffold)
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# DeepSeek AI (Hype AI chatbot)
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
