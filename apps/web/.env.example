# ── Backend connection ────────────────────────────────────────────────────────
# URL of the deployed API service — no trailing slash
# In Railway: set to https://<api-service>.up.railway.app/api
NEXT_PUBLIC_API_URL=https://your-api-service.up.railway.app/api

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Get from https://dash.cloudflare.com → Turnstile → Site key (public)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── App identity (optional) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Hype Tech Hub
