# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — use the external DB URL provided by Railway/Neon
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the deployed frontend — no trailing slash
FRONTEND_URL=https://your-web-service.up.railway.app

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be an authorized redirect URI in Google Console
# Format: https://<api-service-url>/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://your-api-service.up.railway.app/api/auth/google/callback

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Get from https://dash.cloudflare.com → Turnstile → Secret key
TURNSTILE_SECRET_KEY=

# ── AI (optional) ─────────────────────────────────────────────────────────────
# DeepSeek API key — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ── Media (optional) ──────────────────────────────────────────────────────────
# Pexels API key — https://www.pexels.com/api/
PEXELS_API_KEY=
DEFAULT_VIDEO_PLACEHOLDER_URL=https://placehold.co/600x400?text=Hype+Tech+Hub
